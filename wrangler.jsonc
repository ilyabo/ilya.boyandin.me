{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ilya-boyandin-me",
  "compatibility_date": "2026-06-09",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "ilya.boyandin.me",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
