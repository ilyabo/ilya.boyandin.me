---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ilya Boyandin - Data Visualization Engineer',
  description = 'I develop interactive maps and data visualizations for the web.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="bg-site-blue text-white">
      <nav class="mx-auto flex max-w-7xl items-center justify-center gap-2 px-6 font-bold">
        <a class="px-4 py-3 hover:bg-white/80 hover:text-site-blue" href="/">Home</a>
        <a class="px-4 py-3 hover:bg-white/80 hover:text-site-blue" href="/projects">Projects</a>
        <a class="px-4 py-3 hover:bg-white/80 hover:text-site-blue" href="/talks">Talks</a>
        <a class="px-4 py-3 hover:bg-white/80 hover:text-site-blue" href="/music">Music</a>
      </nav>
    </header>
    <main class="mx-auto max-w-7xl px-8 py-10 sm:px-12">
      <slot />
    </main>
  </body>
</html>
