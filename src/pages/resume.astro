---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getResume } from '../lib/resume';
import { pageTitle } from '../lib/seo';

const resume = await getResume();
const title = pageTitle('Resume');
const description = 'Resume of Ilya Boyandin, software engineer specializing in interactive systems, maps, geospatial analytics, and data visualization.';
---

<BaseLayout title={title} description={description} canonicalPath="/resume">
  <article class="resume" data-resume-mode="short">
    <header class="resume-header">
      <a href="/" aria-label="Ilya Boyandin home">
        <img src={resume.profile.image} alt={resume.profile.name} width="120" height="120" />
      </a>
      <div>
        <h1>{resume.profile.name}</h1>
        <p>{resume.profile.subtitle}</p>
      </div>
      <address>
        {resume.profile.contacts.map((contact) => <a href={contact.href}>{contact.label}</a>)}
      </address>
    </header>

    <div class="resume-controls" aria-label="Resume length">
      <button type="button" data-resume-mode-button="short" aria-pressed="true">Short</button>
      <button type="button" data-resume-mode-button="full" aria-pressed="false">Full version</button>
    </div>

    <p class="resume-summary" set:html={resume.summaryHtml} />

    {
      resume.sections.map((section) => {
        if (section.type === 'bullets') {
          return (
            <section id={section.id} data-short={String(section.short)}>
              <h2>{section.title}</h2>
              <ul>
                {section.items.map((item) => (
                  <li data-short={String(item.short)} set:html={item.html} />
                ))}
              </ul>
            </section>
          );
        }

        if (section.type === 'education') {
          return (
            <section id={section.id} data-short={String(section.short)}>
              <h2>{section.title}</h2>
              {section.items.map((item) => (
                <div class="resume-item" data-short={String(item.short)}>
                  <h3>{item.title}, {item.institution}, {item.date}</h3>
                  <dl class="resume-details">
                    {item.details.map((detail) => (
                      <div data-short={String(detail.short)}>
                        <dt>{detail.label}</dt>
                        <dd set:html={detail.html} />
                      </div>
                    ))}
                  </dl>
                </div>
              ))}
            </section>
          );
        }

        if (section.type === 'experience') {
          return (
            <section id={section.id} data-short={String(section.short)}>
              <h2>{section.title}</h2>
              {section.items.map((job) => (
                <div class="resume-item" data-short={String(job.short)}>
                  <h3>
                    <span>{job.title}</span>
                    {job.employer ? ', ' : ''}
                    {job.employerUrl ? <a href={job.employerUrl}>{job.employer}</a> : job.employer}
                  </h3>
                  <p>
                    {[job.start, job.end].filter(Boolean).join(' - ')}
                    {job.location ? ` | ${job.location}` : ''}
                  </p>
                  <ul>
                    {job.bullets.map((bullet) => (
                      <li data-short={String(bullet.short)} set:html={bullet.html} />
                    ))}
                  </ul>
                </div>
              ))}
            </section>
          );
        }

        return (
          <section id={section.id} data-short={String(section.short)}>
            <h2>{section.title}</h2>
            <dl class="resume-expertise">
              {section.groups.map((group) => (
                <div data-short={String(group.short)}>
                  <dt>{group.label}</dt>
                  <dd set:html={group.html} />
                </div>
              ))}
            </dl>
          </section>
        );
      })
    }

    <p class="resume-more"><a href="/talks">Full public speaking archive</a></p>
  </article>

  <script>
    const resume = document.querySelector('[data-resume-mode]');
    const buttons = document.querySelectorAll('[data-resume-mode-button]');
    const setMode = (mode) => {
      if (!resume) return;
      resume.setAttribute('data-resume-mode', mode);
      buttons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.getAttribute('data-resume-mode-button') === mode));
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const mode = button.getAttribute('data-resume-mode-button') || 'short';
        setMode(mode);
      });
    });
  </script>
</BaseLayout>
