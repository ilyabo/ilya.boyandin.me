---
import type { ContentEntry } from '../lib/content';
import { formatDate } from '../lib/format';
import { previewMediaPath } from '../lib/media';

interface Props {
  entries: ContentEntry[];
}

const { entries } = Astro.props;
---

<div class="content-grid">
  {
    entries.map((entry) => {
      const preview = previewMediaPath(entry);

      return (
        <a class="content-card" href={entry.route}>
          <div class="card-heading">
            <h2>{entry.title}</h2>
            <span>{formatDate(entry.date)}</span>
          </div>
          <div class="preview-frame">
            {preview ? <img src={preview} alt={`${entry.title} preview`} loading="lazy" /> : null}
          </div>
        </a>
      );
    })
  }
</div>
